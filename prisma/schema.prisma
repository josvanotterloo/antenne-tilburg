// Antenne Tilburg — database schema
// See docs/antenne-tilburg-website-plan.md for the product/domain rationale.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Condition {
  NEW
  SECONDHAND
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

// Two equal admin accounts (shop owner + builder). No role tiers.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// --- Managed reference lists (each has its own admin CRUD) ---

model Label {
  id        String    @id @default(cuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Genre {
  id        String    @id @default(cuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ProductType {
  id        String    @id @default(cuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Vinyl / tape records. `price` is present now so online purchasing can be
// added later without a schema migration. "Just In" is derived from createdAt
// (< 30 days) — no manual flag.
model Product {
  id            String      @id @default(cuid())
  title         String
  artist        String
  catalogNumber String?
  labelId       String
  label         Label       @relation(fields: [labelId], references: [id])
  productTypeId String
  productType   ProductType @relation(fields: [productTypeId], references: [id])
  genreId       String
  genre         Genre       @relation(fields: [genreId], references: [id])
  condition     Condition
  price         Decimal     @db.Decimal(10, 2)
  description   String?
  coverImage    String?
  quantity      Int         @default(0)
  // Derived from quantity (> 0) and kept in sync on every write; public queries
  // filter on it. See lib/product-input.ts (toProductData) and the sell-one route.
  inStock       Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Postgres full-text search column — a generated STORED tsvector defined in a
  // manual migration. Declared here as Unsupported so Prisma treats it as
  // existing (no drift) but does not try to query it directly.
  searchVector  Unsupported("tsvector")? @map("search_vector")

  @@index([labelId])
  @@index([productTypeId])
  @@index([genreId])
  @@index([condition])
  @@index([inStock])
  @@index([createdAt])
}

// Blog posts (new arrivals, events, restocks). Also feeds SEO via fresh content.
model Post {
  id             String     @id @default(cuid())
  title          String
  slug           String     @unique
  body           String
  coverImage     String?
  status         PostStatus @default(DRAFT)
  publishedAt    DateTime?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

// Site-wide banners. Multiple can be active at once. If startsAt/endsAt are set
// the notice activates/deactivates automatically; otherwise `active` is manual.
model Notice {
  id        String    @id @default(cuid())
  message   String
  active    Boolean   @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// One row per weekday (0 = Sunday ... 6 = Saturday). Times stored as "HH:MM".
model OpeningHours {
  id        String  @id @default(cuid())
  dayOfWeek Int     @unique
  opensAt   String
  closesAt  String
  closed    Boolean @default(false)
}

// Per-static-page SEO overrides (Home, About, FAQ, Visit, ...).
model PageSeo {
  id             String  @id @default(cuid())
  page           String  @unique
  seoTitle       String?
  seoDescription String?
}

enum SubscriberStatus {
  PENDING
  CONFIRMED
}

model NewsletterSubscriber {
  id           String           @id @default(cuid())
  name         String
  // AES-256-GCM ciphertext ("v1:iv:ct:tag" — see lib/email-crypto.ts). Rows
  // created before encryption hold legacy plaintext until the one-time
  // migration script runs; decryptEmail passes those through unchanged.
  email        String
  // Keyed HMAC-SHA-256 of the normalized address. Unique so signup detects
  // duplicates without a plaintext column. Nullable only for unmigrated
  // legacy rows (backfilled by scripts/encrypt-subscriber-emails.ts).
  emailHash    String?          @unique
  status       SubscriberStatus @default(PENDING)
  // Generated at signup for the confirm link; retained after confirmation so it
  // doubles as the one-click unsubscribe token.
  confirmToken String           @unique
  createdAt    DateTime         @default(now())
}

// Public "looking for" requests — feeds sourcing decisions.
model WantListRequest {
  id        String   @id @default(cuid())
  artist    String
  title     String
  format    String
  notes     String?
  createdAt DateTime @default(now())
}
